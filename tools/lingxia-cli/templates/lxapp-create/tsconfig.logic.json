{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.logic.tsbuildinfo",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "types": ["@lingxia/types", "@lingxia/types/logic-globals"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@lingxia/page-types/*": ["./.lingxia/types/*"]
    }
  },
  "include": ["lxapp.ts", "lxapp.config.ts", "pages/**/*.ts", "shared/**/*.ts", ".lingxia/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "pages/**/entry.ts"]
}
