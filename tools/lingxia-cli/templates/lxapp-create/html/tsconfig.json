{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noEmit": true
  },
  "include": ["**/*.ts", ".lingxia/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
