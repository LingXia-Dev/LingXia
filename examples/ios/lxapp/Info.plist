<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>app.lingxia.example.lxapp</string>

    <!-- Push Notifications Configuration -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>

    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>

    <!-- Location permission description for runtime prompts -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Allow LingXia to access your location to provide location-based features.</string>

    <!-- Photos library permission descriptions -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Allow LingXia to save images and videos to your photo library.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Allow LingXia to access your photo library for media features.</string>
</dict>
</plist>
