<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>app.lingxia.example.lxapp</string>

    <!-- Supported localizations -->
    <key>CFBundleLocalizations</key>
    <array>
        <string>en</string>
        <string>zh-Hans</string>
    </array>

    <!-- Push Notifications Configuration -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>

    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>

    <!-- Location permission description for runtime prompts -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Allow LingXia to access your location to provide location-based features.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>Allow LingXia to access your location to read WiFi information.</string>

    <!-- Photos library permission descriptions -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Allow LingXia to save images and videos to your photo library.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Allow LingXia to access your photo library for media features.</string>

    <!-- Camera and microphone permission descriptions -->
    <key>NSCameraUsageDescription</key>
    <string>Allow LingXia to capture photos and videos through the camera.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Allow LingXia to record audio when capturing videos.</string>

    <!-- Disable rotation -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
</dict>
</plist>
