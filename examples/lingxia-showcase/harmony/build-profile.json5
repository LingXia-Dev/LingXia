{
  "app": {
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "6.0.1(21)",
        "compatibleSdkVersion": "6.0.1(21)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug",
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      // SDK source module — mirrors the Android example's `include(":lingxia")`
      // wiring so edits to lingxia-sdk/harmony/lingxia/... rebuild on the next
      // app build with no `.har` packaging or `ohpm install` round-trip.
      "name": "lingxia",
      "srcPath": "../../../lingxia-sdk/harmony/lingxia"
    }
  ]
}
