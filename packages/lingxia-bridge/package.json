{
  "name": "@lingxia/bridge",
  "version": "0.4.3",
  "private": false,
  "description": "LingXia Web Runtime - Bridge, boot, and error handling for WebView",
  "type": "module",
  "main": "dist/runtime.es2020.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/runtime.es2020.js"
    },
    "./dist/runtime.es2020.js": "./dist/runtime.es2020.js",
    "./dist/runtime.es5.js": "./dist/runtime.es5.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && npm run build:es2020 && npm run build:es5 && npm run build:types",
    "build:es2020": "RUNTIME_OUTPUT=runtime.es2020.js rolldown -c",
    "build:es5": "node ./scripts/build-es5.mjs",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "rolldown -c -w",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.3",
    "rolldown": "^1.0.0-rc.13",
    "rollup-plugin-esbuild": "^6.2.1",
    "terser": "^5.39.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT"
}
