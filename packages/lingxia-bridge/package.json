{
  "name": "@lingxia/bridge",
  "version": "0.10.0",
  "private": false,
  "description": "LingXia Web Runtime - Bridge, boot, and error handling for WebView",
  "repository": {
    "type": "git",
    "url": "https://github.com/LingXia-Dev/LingXia.git",
    "directory": "packages/lingxia-bridge"
  },
  "type": "module",
  "main": "dist/es2020/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/es2020/index.js"
    },
    "./es5": {
      "types": "./dist/index.d.ts",
      "default": "./dist/es5/index.js"
    },
    "./invocation": {
      "types": "./dist/invocation.d.ts",
      "default": "./dist/es2020/invocation.js"
    },
    "./invocation/es5": {
      "types": "./dist/invocation.d.ts",
      "default": "./dist/es5/invocation.js"
    },
    "./dist/bridge-runtime.es2020.js": "./dist/bridge-runtime.es2020.js",
    "./dist/bridge-runtime.es5.js": "./dist/bridge-runtime.es5.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && npm run build:es2020 && npm run build:es5 && npm run build:modules:es2020 && npm run build:modules:es5 && npm run build:types",
    "build:es2020": "node ./scripts/build-es2020.mjs",
    "build:es5": "node ./scripts/build-es5.mjs",
    "build:modules:es2020": "tsc -p tsconfig.modules.json",
    "build:modules:es5": "tsc -p tsconfig.modules.legacy.json",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "rolldown -c -w",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "rolldown": "^1.0.0-rc.13",
    "terser": "^5.39.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT"
}
