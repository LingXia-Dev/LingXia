{
  "name": "@lingxia/react",
  "version": "0.7.0",
  "private": false,
  "description": "LingXia React runtime and components for lxapp pages",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && npm --prefix ../lingxia-elements run build && npm --prefix ../lingxia-page-runtime run build && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@lingxia/bridge": "0.7.0",
    "@lingxia/elements": "0.7.0",
    "@lingxia/page-runtime": "0.7.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@lingxia/bridge": "file:../lingxia-bridge",
    "@lingxia/elements": "file:../lingxia-elements",
    "@lingxia/page-runtime": "file:../lingxia-page-runtime",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LingXia-Dev/LingXia.git",
    "directory": "packages/lingxia-react"
  },
  "license": "MIT"
}
