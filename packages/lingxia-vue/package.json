{
  "name": "@lingxia/vue",
  "version": "0.4.3",
  "private": false,
  "description": "LingXia Vue bindings — useLingXia composable and native components for Vue",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@lingxia/bridge": ">=0.4.0",
    "@lingxia/elements": ">=0.4.0"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@lingxia/bridge": "file:../lingxia-bridge",
    "@lingxia/elements": "file:../lingxia-elements",
    "typescript": "^5.7.2",
    "vue": "^3.5.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LingXia-Dev/LingXia.git",
    "directory": "packages/lingxia-vue"
  },
  "license": "MIT"
}
