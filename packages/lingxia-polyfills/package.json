{
  "name": "@lingxia/polyfills",
  "version": "0.9.0",
  "private": false,
  "description": "ES5 stdlib polyfills shipped to the lxapp runtime when targeting old Android WebView (Chromium 37–44).",
  "repository": {
    "type": "git",
    "url": "https://github.com/LingXia-Dev/LingXia.git",
    "directory": "packages/lingxia-polyfills"
  },
  "type": "module",
  "main": "dist/polyfills.es5.js",
  "exports": {
    ".": "./dist/polyfills.es5.js",
    "./dist/polyfills.es5.js": "./dist/polyfills.es5.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs && npm run check",
    "check": "node ./scripts/check.mjs",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "terser": "^5.39.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT"
}
