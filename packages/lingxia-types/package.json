{
  "name": "@lingxia/types",
  "version": "0.10.0",
  "description": "TypeScript type definitions for the LingXia JS API",
  "repository": {
    "type": "git",
    "url": "https://github.com/LingXia-Dev/LingXia.git",
    "directory": "packages/lingxia-types"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "import": "./dist/app/index.js",
      "require": "./dist/app/index.js"
    },
    "./surface": {
      "types": "./dist/surface/index.d.ts",
      "import": "./dist/surface/index.js",
      "require": "./dist/surface/index.js"
    },
    "./lxapp": {
      "types": "./dist/lxapp/index.d.ts",
      "import": "./dist/lxapp/index.js",
      "require": "./dist/lxapp/index.js"
    },
    "./device": {
      "types": "./dist/device/index.d.ts",
      "import": "./dist/device/index.js",
      "require": "./dist/device/index.js"
    },
    "./display": {
      "types": "./dist/display/index.d.ts",
      "import": "./dist/display/index.js",
      "require": "./dist/display/index.js"
    },
    "./input": {
      "types": "./dist/input/index.d.ts",
      "import": "./dist/input/index.js",
      "require": "./dist/input/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js",
      "require": "./dist/env/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.js"
    },
    "./file": {
      "types": "./dist/file/index.d.ts",
      "import": "./dist/file/index.js",
      "require": "./dist/file/index.js"
    },
    "./transfer": {
      "types": "./dist/transfer/index.d.ts",
      "import": "./dist/transfer/index.js",
      "require": "./dist/transfer/index.js"
    },
    "./location": {
      "types": "./dist/location/index.d.ts",
      "import": "./dist/location/index.js",
      "require": "./dist/location/index.js"
    },
    "./navigator": {
      "types": "./dist/navigator/index.d.ts",
      "import": "./dist/navigator/index.js",
      "require": "./dist/navigator/index.js"
    },
    "./system": {
      "types": "./dist/system/index.d.ts",
      "import": "./dist/system/index.js",
      "require": "./dist/system/index.js"
    },
    "./update": {
      "types": "./dist/update/index.d.ts",
      "import": "./dist/update/index.js",
      "require": "./dist/update/index.js"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "import": "./dist/media/index.js",
      "require": "./dist/media/index.js"
    },
    "./share": {
      "types": "./dist/share/index.d.ts",
      "import": "./dist/share/index.js",
      "require": "./dist/share/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.js"
    },
    "./error": {
      "types": "./dist/error.d.ts",
      "import": "./dist/error.js",
      "require": "./dist/error.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "gen:i18n": "node scripts/gen-i18n.mjs",
    "build": "npm run gen:i18n && tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "keywords": [
    "lingxia",
    "lxapp",
    "miniapp",
    "types",
    "typescript",
    "definitions"
  ],
  "author": "LingXia Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false
}
