{
  "name": "@lingxia/types",
  "version": "0.10.0",
  "description": "TypeScript type definitions for the LingXia JS API",
  "repository": {
    "type": "git",
    "url": "https://github.com/LingXia-Dev/LingXia.git",
    "directory": "packages/lingxia-types"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./logic-globals": {
      "types": "./dist/logic-globals.d.ts"
    },
    "./app": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./surface": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./lxapp": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./device": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./display": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./input": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./env": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./storage": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./file": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./transfer": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./location": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./navigator": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./system": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./update": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./media": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./share": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./ui": {
      "types": "./dist/generated/logic.d.ts",
      "import": "./dist/generated/logic.js",
      "require": "./dist/generated/logic.js"
    },
    "./error": {
      "types": "./dist/error.d.ts",
      "import": "./dist/error.js",
      "require": "./dist/error.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "gen:i18n": "node scripts/gen-i18n.mjs",
    "gen:logic": "node scripts/gen-logic.mjs",
    "gen": "npm run gen:i18n && npm run gen:logic",
    "check:logic": "npm run gen:logic -- --check",
    "check:quality": "node scripts/check-generated-quality.mjs",
    "build": "npm run gen && tsc && mkdir -p dist/generated && cp src/logic-globals.d.ts dist/logic-globals.d.ts && cp src/generated/logic-web.d.ts dist/generated/logic-web.d.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "keywords": [
    "lingxia",
    "lxapp",
    "miniapp",
    "types",
    "typescript",
    "definitions"
  ],
  "author": "LingXia Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false
}
