{
  "name": "@lingxia/page-runtime",
  "version": "0.5.0",
  "private": false,
  "description": "LingXia page runtime for HTML, React, and Vue lxapp views",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./html": {
      "types": "./dist/html/index.d.ts",
      "default": "./dist/html/index.js"
    },
    "./html/global": "./dist/html/global.js",
    "./html/global-legacy": "./dist/html/global.es5.js",
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "default": "./dist/vue/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && node ./scripts/build-html-global.mjs && mkdir -p dist/vue && cp src/vue/*.vue dist/vue/",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@lingxia/bridge": ">=0.5.0",
    "@lingxia/elements": ">=0.5.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lingxia/bridge": "file:../lingxia-bridge",
    "@lingxia/elements": "file:../lingxia-elements",
    "@types/react": "^19.2.7",
    "react": "^19.0.0",
    "rolldown": "^1.0.0-rc.13",
    "typescript": "^5.7.2",
    "vue": "^3.5.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LingXia-Dev/LingXia.git",
    "directory": "packages/lingxia-page-runtime"
  },
  "license": "MIT"
}
