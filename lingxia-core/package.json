{
  "name": "@lingxia/core",
  "version": "0.3.0",
  "private": false,
  "description": "LingXia Web Runtime - Bridge, boot, and error handling for WebView",
  "type": "module",
  "main": "dist/runtime.es2020.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/runtime.es2020.js"
    },
    "./dist/runtime.es2020.js": "./dist/runtime.es2020.js",
    "./dist/runtime.es5.js": "./dist/runtime.es5.js",
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "default": "./dist/vue.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && npm run build:es2020 && npm run build:es5 && npm run build:types && npm run build:modules",
    "build:es2020": "RUNTIME_OUTPUT=runtime.es2020.js rollup -c",
    "build:es5": "TARGET=es5 LX_RUNTIME_PLATFORM=mobile RUNTIME_OUTPUT=runtime.es5.js rollup -c",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build:modules": "tsc -p tsconfig.modules.json",
    "dev": "rollup -c -w",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.0.0",
    "rollup": "^4.54.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.0",
    "vue": "^3.5.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT"
}
